  {
    "id": "tableViewer1",
    "type": "table_viewer",
    "label": "Просмотр таблицы районов",
    "dataSource": "districtFactors"
  },
  {
    "id": "formulaNp",
    "type": "formula",
    "formula": "ceil((inputAreaFlats / livingNormMkd) * 0.257 * k1Range)",
    "dependencies": ["inputAreaFlats", "livingNormMkd", "k1Range"]
  },
  {
    "id": "formulaNpMinus",
    "type": "formula",
    "formula": "ceil(formulaNp * 0.9)",
    "dependencies": ["formulaNp"]
  },
  {
    "id": "formulaNpPlus",
    "type": "formula",
    "formula": "floor(formulaNp * 1.1)",
    "dependencies": ["formulaNp"]
  },
  {
    "id": "formulaNv",
    "type": "formula",
    "formula": "ceil((inputAreaNNP / 90) * k1Range * k2Lookup)",
    "dependencies": ["inputAreaNNP", "k1Range", "k2Lookup"]
  },
  {
    "id": "formulaNvMinus",
    "type": "formula",
    "formula": "ceil(formulaNv * 0.7)",
    "dependencies": ["formulaNv"]
  },
  {
    "id": "formulaNvPlus",
    "type": "formula",
    "formula": "floor(formulaNv * 1.3)",
    "dependencies": ["formulaNv"]
  },
  {
    "id": "formulaNkResidential",
    "type": "formula",
    "formula": "ceil(inputAreaFlats / moRateLiving)",
    "dependencies": ["inputAreaFlats", "moRateLiving"]
  },
  {
    "id": "formulaNkCommercial",
    "type": "formula",
    "formula": "min(4, ceil(inputAreaNNP / moRateCommercial))",
    "dependencies": ["inputAreaNNP", "moRateCommercial"]
  },
  {
    "id": "formulaNkSchool",
    "type": "formula",
    "formula": "ceil(inputSchoolCapacity / moRateSchool)",
    "dependencies": ["inputSchoolCapacity", "moRateSchool"]
  },
  {
    "id": "formulaNkPreschool",
    "type": "formula",
    "formula": "ceil(inputKindergartenCapacity / moRateKindergarten)",
    "dependencies": ["inputKindergartenCapacity", "moRateKindergarten"]
  },
  {
    "id": "formulaNkTotal",
    "type": "formula",
    "formula": "formulaNkResidential + formulaNkCommercial + formulaNkSchool + formulaNkPreschool",
    "dependencies": ["formulaNkResidential", "formulaNkCommercial", "formulaNkSchool", "formulaNkPreschool"]
  },
  {
    "id": "formulaNg",
    "type": "formula",
    "formula": "ceil(formulaNp * 0.1)",
    "dependencies": ["formulaNp"]
  },
  {
    "id": "formulaNgMinus",
    "type": "formula",
    "formula": "ceil(formulaNg * 0.9)",
    "dependencies": ["formulaNg"]
  },
  {
    "id": "formulaNgPlus",
    "type": "formula",
    "formula": "floor(formulaNg * 1.1)",
    "dependencies": ["formulaNg"]
  },
  {
    "id": "formulaTotal",
    "type": "formula",
    "formula": "formulaNp + formulaNg + formulaNv + formulaNkTotal",
    "dependencies": ["formulaNp", "formulaNg", "formulaNv", "formulaNkTotal"]
  },
  {
    "id": "formulaEvPlaces",
    "type": "formula",
    "formula": "ceil(formulaNp * evShareLookup) + ceil(formulaNg * evShareLookup) + ceil(formulaNv * evShareLookup)",
    "dependencies": ["formulaNp", "formulaNg", "formulaNv", "evShareLookup"]
  },
  {
    "id": "formulaParkingArea",
    "type": "formula",
    "formula": "ceil(formulaTotal * inputSqmPerPlace)",
    "dependencies": ["formulaTotal", "inputSqmPerPlace"]
  },
  {
    "id": "formulaParkingArea2",
    "type": "formula",
    "formula": "ceil(formulaParkingArea / 2)",
    "dependencies": ["formulaParkingArea"]
  },
  {
    "id": "outputTotal",
    "type": "output",
    "label": "Итого требуется",
    "sourceId": "formulaTotal"
  },
  {
    "id": "outputEv",
    "type": "output",
    "label": "Электромобили",
    "sourceId": "formulaEvPlaces"
  },
  {
    "id": "outputParkingArea",
    "type": "output",
    "label": "Площадь стоянки",
    "sourceId": "formulaParkingArea"
  },
  {
    "id": "outputParkingArea2",
    "type": "output",
    "label": "Площадь стоянки (2 ур.)",
    "sourceId": "formulaParkingArea2"
  }
]
