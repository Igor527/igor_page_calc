  {
    "id": "formulaNp",
    "type": "formula",
    "formula": "ceil((inputAreaFlats / livingNormMkd) * 0.257 * k1Range)",
    "dependencies": [
      "inputAreaFlats",
      "livingNormMkd",
      "k1Range"
    ]
  },
  {
    "id": "formulaNpMinus",
    "type": "formula",
    "formula": "ceil(formulaNp * 0.9)",
    "dependencies": [
      "formulaNp"
    ]
  },
  {
    "id": "formulaNpPlus",
    "type": "formula",
    "formula": "floor(formulaNp * 1.1)",
    "dependencies": [
      "formulaNp"
    ]
  },
  {
    "id": "formulaNv",
    "type": "formula",
    "formula": "ceil((inputAreaNNP / 90) * k1Range * k2Lookup)",
    "dependencies": [
      "inputAreaNNP",
      "k1Range",
      "k2Lookup"
