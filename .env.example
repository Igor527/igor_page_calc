# Скопируйте в .env и подставьте свои значения. Файл .env в git не попадает.

# Mistral AI — перевод в словаре (https://console.mistral.ai/)
VITE_MISTRAL_API_KEY=ваш_ключ_mistral

# Firebase Auth — вход в режим админа (Firebase Console → настройки проекта → General → Your apps)
# В Authorized domains добавьте: localhost, 127.0.0.1, urbanplanner.page, www.urbanplanner.page
VITE_FIREBASE_API_KEY=ваш_api_key
VITE_FIREBASE_AUTH_DOMAIN=ваш-проект.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=ваш-проект
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef

# Кто может войти как админ: email и/или GitHub User ID (несколько через запятую)
# Для входа через Google укажите ваш Gmail в VITE_ADMIN_EMAIL
# GitHub ID покажется в ошибке при первом входе, если не в списке
VITE_ADMIN_EMAIL=your@email.com
VITE_ADMIN_GITHUB_IDS=12345678

# Ограниченный гость: один или несколько email через запятую. Им доступны только «Планировщик (списки дел)» и «Метеостанция». Вход по /welcome_me.
VITE_GUEST_EMAIL=guest@example.com

# Синхронизация с GitHub (подстановка в форму «Синхронизация с GitHub»). Токен не сюда — только в форме, хранится в localStorage.
VITE_GITHUB_SYNC_OWNER=username
VITE_GITHUB_SYNC_REPO=igor_page_calc
VITE_GITHUB_SYNC_BRANCH=main
